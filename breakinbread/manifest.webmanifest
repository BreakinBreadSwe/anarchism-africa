{
  "name": "Breakin Bread — Free Cinema",
  "short_name": "Breakin Bread",
  "description": "A free cinema of public-domain films and movies. No paywall, no login, no ads.",
  "id": "/breakinbread/",
  "start_url": "/breakinbread/",
