# ===== ANARCHISM.AFRICA — environment template =====
# Copy to .env.local for local dev, or paste into Vercel project env vars.

# ----- Storage -----
# Vercel Blob — Vercel sets this automatically when you enable Blob on the project.
# Dashboard → Storage → Connect → Blob → Create
BLOB_READ_WRITE_TOKEN=

# Optional: Supabase (if you prefer Postgres + auth + RLS instead of Blob)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# Optional: Neon (Postgres only)
NEON_DATABASE_URL=

# ----- AI providers (only set the ones you use) -----
GEMINI_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
GLM_API_KEY=
YI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ----- POD providers -----
PRINTFUL_API_KEY=
TEEMILL_API_KEY=
GELATO_API_KEY=

# ----- Mailing -----
RESEND_API_KEY=
LISTMONK_URL=
LISTMONK_USER=
LISTMONK_PASS=
