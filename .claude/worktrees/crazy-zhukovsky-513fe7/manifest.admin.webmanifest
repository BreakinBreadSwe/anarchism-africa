{
  "name": "STUDIO \u00b7 LUVLAB \u00b7 ANARCHISM.AFRICA",
  "short_name": "Studio",
  "description": "Backend CMS for ANARCHISM.AFRICA \u2014 content, marketplace, ambassadors, mailing, AI.",
  "start_url": "/admin.html",
  "scope": "/admin.html",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#000000",
  "theme_color": "#000000",
