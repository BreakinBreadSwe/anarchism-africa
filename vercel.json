{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/cron/scan-content",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/generate-articles",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/generate-slogans",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/generate-logos",
      "schedule": "0 15 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|svg|png|jpg|webp|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
